# Erion Ember - Environment Configuration
# cp .env.example .env

# Vector Index Backend: 'annoy' (JS), 'hnsw' (C++), 'qdrant' (Cloud), 'turso' (libSQL)
VECTOR_INDEX_BACKEND=annoy

# Qdrant Configuration (Required if VECTOR_INDEX_BACKEND=qdrant)
QDRANT_URL=https://<your-cluster-url>.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=erion_cache

# Turso Configuration (Required if VECTOR_INDEX_BACKEND=turso)
TURSO_URL=libsql://<your-db-url>.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Cache Configuration
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_MAX_ELEMENTS=100000
CACHE_DEFAULT_TTL=3600

# Environment
NODE_ENV=development
