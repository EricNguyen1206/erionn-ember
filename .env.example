# Erion Ember v3 — Environment Configuration
# cp .env.example .env

# ─── Server ──────────────────────────────────────────────
HTTP_PORT=8080

# ─── Cache ───────────────────────────────────────────────
# Cosine similarity threshold for semantic cache hits (0.0 – 1.0)
CACHE_SIMILARITY_THRESHOLD=0.85

# Maximum number of cached entries (LRU eviction when exceeded)
CACHE_MAX_ELEMENTS=100000

# Default TTL in seconds (0 = no expiry)
CACHE_DEFAULT_TTL=3600

# ─── Embedding Worker Pool ────────────────────────────────
# Number of embedding worker goroutines (0 = runtime.NumCPU())
EMBED_WORKERS=4

# ─── Semantic Similarity via Ollama (pure Go HTTP, no CGO) ───────────────
# Leave OLLAMA_URL empty → exact-match only mode (default, Ollama not required)
# To enable:
#   1. Install Ollama:   https://ollama.com/download
#   2. Pull a model:     ollama pull nomic-embed-text
#   3. Set URL below:
OLLAMA_URL=
# Recommended models: nomic-embed-text (768-dim), all-minilm (384-dim), mxbai-embed-large (1024-dim)
OLLAMA_MODEL=nomic-embed-text
